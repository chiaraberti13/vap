# .env.example
# Copia questo file in .env e personalizza i valori.
# Nota: i valori vuoti indicano impostazioni opzionali o da impostare in produzione.

# ==============================
# Server Configuration
# ==============================
VAP_ENV=development
VAP_HOST=0.0.0.0
VAP_PORT=8000
VAP_REQUIRE_HTTPS=false
VAP_TLS_CERTFILE=
VAP_TLS_KEYFILE=
VAP_TLS_CA_CERTS=

# ==============================
# Database
# ==============================
VAP_DATABASE_URL=sqlite:///./vap.db
VAP_SQLCIPHER_KEY=

# ==============================
# Reports & Storage
# ==============================
VAP_REPORTS_DIR=reports
VAP_SCAN_RETENTION_DAYS=30
VAP_SCAN_ARCHIVE_AFTER_DAYS=7

# ==============================
# Scanning & Concurrency
# ==============================
VAP_SCAN_TIMEOUT=300
VAP_ENABLE_LIVE_SCANS=false
VAP_MAX_FINDINGS=200
VAP_MAX_CONCURRENT_SCANNERS=5

# ==============================
# Authentication & API Security
# ==============================
VAP_API_KEY=
VAP_API_KEY_HASH=
VAP_CSRF_SECRET=
VAP_CSRF_COOKIE=vap_csrf
VAP_CSRF_TTL=3600
VAP_JWT_SECRET=
VAP_JWT_ALGORITHM=HS256
VAP_JWT_ISSUER=vap
VAP_JWT_AUDIENCE=vap-users
VAP_JWT_EXP_MINUTES=60
VAP_JWT_REQUIRED=false
VAP_JWT_DEMO_USER=
VAP_JWT_DEMO_PASSWORD=
VAP_TRUSTED_PROXY_IP=

# ==============================
# CORS
# ==============================
VAP_CORS_ALLOWED_ORIGINS=
VAP_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
VAP_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key
VAP_CORS_ALLOW_CREDENTIALS=false

# ==============================
# Rate Limiting
# ==============================
VAP_RATE_LIMIT_DEFAULT=120/minute
VAP_RATE_LIMIT_CREATE_SCAN=10/minute
VAP_RATE_LIMIT_AUTH=15/minute
VAP_RATE_LIMIT_READ=120/minute

# ==============================
# Security Headers
# ==============================
VAP_HSTS_MAX_AGE=31536000
VAP_CSP_POLICY=default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; connect-src 'self'; frame-ancestors 'none'
VAP_SECURITY_HEADERS=true

# ==============================
# Compliance & Audit
# ==============================
VAP_AUDIT_LOGGING=true
VAP_PRIVACY_POLICY_VERSION=2024-01
VAP_TERMS_VERSION=2024-01
VAP_CONSENT_RETENTION_DAYS=365
VAP_AUDIT_RETENTION_DAYS=365

# ==============================
# Nuclei
# ==============================
VAP_NUCLEI_RATE_LIMIT=150
VAP_NUCLEI_TIMEOUT=10
VAP_NUCLEI_SEVERITIES=critical,high,medium,low,info
VAP_NUCLEI_TEMPLATES=
VAP_NUCLEI_UPDATE_TEMPLATES=true
VAP_NUCLEI_ADDITIONAL_ARGS=

# ==============================
# Nmap
# ==============================
VAP_NMAP_PROFILE=quick
VAP_NMAP_ADDITIONAL_ARGS=

# ==============================
# Enrichment APIs
# ==============================
VAP_SECURITYTRAILS_API_KEY=
VAP_VIRUSTOTAL_API_KEY=
VAP_SHODAN_API_KEY=

# ==============================
# Subfinder
# ==============================
VAP_SUBFINDER_SOURCES=
VAP_SUBFINDER_RESOLVE_LIMIT=200

# ==============================
# Dirsearch
# ==============================
VAP_DIRSEARCH_PATH=dirsearch
VAP_DIRSEARCH_WORDLIST=
VAP_DIRSEARCH_EXTENSIONS=php,asp,aspx,js,html,zip,tar.gz,bak,old,backup
VAP_DIRSEARCH_THREADS=20

# ==============================
# SQLMap
# ==============================
VAP_SQLMAP_PATH=sqlmap
VAP_SQLMAP_LEVEL=2
VAP_SQLMAP_RISK=1
VAP_SQLMAP_CRAWL_DEPTH=1
VAP_SQLMAP_FORMS=true
VAP_SQLMAP_ADDITIONAL_ARGS=

# ==============================
# XSStrike
# ==============================
VAP_XSSTRIKE_PATH=xsstrike
VAP_XSSTRIKE_CRAWL=true
VAP_XSSTRIKE_ADDITIONAL_ARGS=

# ==============================
# OWASP ZAP
# ==============================
VAP_ZAP_API_BASE_URL=
VAP_ZAP_API_KEY=
VAP_ZAP_MAX_ALERTS=200
VAP_ZAP_TIMEOUT=20

# ==============================
# Burp Suite
# ==============================
VAP_BURP_API_BASE_URL=
VAP_BURP_API_KEY=
VAP_BURP_API_SCAN_ENDPOINT=/v0.1/scan
VAP_BURP_API_ISSUES_ENDPOINT=/v0.1/scan/{scan_id}/issues
VAP_BURP_TIMEOUT=20

# ==============================
# Wapiti & Commix
# ==============================
VAP_WAPITI_PATH=wapiti
VAP_COMMIX_PATH=commix
VAP_COMMIX_ADDITIONAL_ARGS=

# ==============================
# Acunetix
# ==============================
VAP_ACUNETIX_API_BASE_URL=
VAP_ACUNETIX_API_KEY=
VAP_ACUNETIX_VULNERABILITIES_ENDPOINT=/api/v1/vulnerabilities
VAP_ACUNETIX_TIMEOUT=20

# ==============================
# Nessus
# ==============================
VAP_NESSUS_API_BASE_URL=
VAP_NESSUS_API_KEY=
VAP_NESSUS_VULNERABILITIES_ENDPOINT=/vulnerabilities
VAP_NESSUS_TIMEOUT=20

# ==============================
# NVD
# ==============================
VAP_NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
VAP_NVD_API_KEY=
VAP_NVD_TIMEOUT=10
VAP_NVD_MAX_CVES=20

# ==============================
# ExploitDB
# ==============================
VAP_EXPLOITDB_SEARCHSPLOIT_PATH=searchsploit
VAP_EXPLOITDB_TIMEOUT=10
VAP_EXPLOITDB_MAX_CVES=20

# ==============================
# False Positive Model
# ==============================
VAP_FP_MEDIUM_THRESHOLD=0.4
VAP_FP_HIGH_THRESHOLD=0.7

# ==============================
# Celery & Redis
# ==============================
VAP_CELERY_BROKER_URL=redis://localhost:6379/0
VAP_CELERY_RESULT_BACKEND=redis://localhost:6379/1
VAP_CELERY_DEFAULT_QUEUE=scans
VAP_CELERY_WORKER_CONCURRENCY=4
VAP_CELERY_TASK_TIME_LIMIT=900
VAP_CELERY_TASK_SOFT_TIME_LIMIT=840
VAP_CELERY_RESULT_EXPIRES=3600

# ==============================
# API Cache
# ==============================
VAP_API_CACHE_ENABLED=true
VAP_API_CACHE_REDIS_URL=redis://localhost:6379/2
VAP_API_CACHE_TTL=30
VAP_API_CACHE_PREFIX=vap:api

# ==============================
# Scheduler & WebSocket
# ==============================
VAP_SCHEDULED_SCANS=[]
VAP_WEBSOCKET_POLL_SECONDS=2.0
