# .env.example
# Copia questo file in .env e personalizza i valori

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False
WORKERS=4

# Database
DATABASE_URL=sqlite:///vuln_scanner.db

# Logging
LOG_LEVEL=info

# Tool Paths (opzionale, se diversi dai default)
# NMAP_PATH=/usr/bin/nmap
# NUCLEI_PATH=/home/user/go/bin/nuclei
# WHATWEB_PATH=/usr/bin/whatweb
# SUBFINDER_PATH=/home/user/go/bin/subfinder
# NIKTO_PATH=/usr/bin/nikto
