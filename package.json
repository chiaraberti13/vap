{
  "name": "vap-frontend",
  "version": "1.0.0",
  "description": "VAP frontend CSS build pipeline",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i assets/css/tailwind.input.css -o static/css/tailwind.min.css --minify",
    "build:css:dev": "tailwindcss -i assets/css/tailwind.input.css -o static/css/tailwind.css",
    "watch:css": "tailwindcss -i assets/css/tailwind.input.css -o static/css/tailwind.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
