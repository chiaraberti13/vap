@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

Person(user, "Security Analyst")
System_Boundary(vap_boundary, "VAP") {
  Container(web, "FastAPI", "Python", "UI + REST API")
  Container(worker, "Celery Worker", "Python", "Esecuzione scansioni")
  Container(db, "SQLite", "DB", "Dati scansioni/report")
  Container(cache, "Redis", "Cache/Queue", "Rate limit + queue")
}
System_Ext(scanner_tools, "Security Tools")

Rel(user, web, "Usa browser/API")
Rel(web, db, "SQLAlchemy")
Rel(web, cache, "redis-py")
Rel(web, worker, "Queue")
Rel(worker, scanner_tools, "CLI/API")
Rel(worker, db, "Aggiorna risultati")
@enduml
