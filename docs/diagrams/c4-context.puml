@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

Person(user, "Security Analyst", "Avvia scansioni e legge report")
System(vap, "Vulnerability Assessment Platform", "Orchestrazione scansioni + reporting")
System_Ext(scanner_tools, "Security Tools", "Nmap, Nuclei, Nikto, ...")
System_Ext(redis, "Redis", "Cache API + queue")
System_Ext(sqlite, "SQLite", "Persistenza scansioni e findings")

Rel(user, vap, "Usa dashboard web / API")
Rel(vap, scanner_tools, "Esegue scansioni")
Rel(vap, redis, "Cache + queue")
Rel(vap, sqlite, "Legge/Scrive dati")
@enduml
